FROM alpine:3.19

RUN apk add --no-cache \
        qemu-system-x86_64 \
        qemu-img \
        qemu-ui-vnc \
        ovmf \
        novnc \
        bash \
    && rm -rf /var/cache/apk/*

RUN addgroup -g 103 kvm 2>/dev/null || true \
    && adduser -D -u 1000 -s /bin/bash container \
    && adduser container kvm

COPY scripts/start.sh /start.sh
RUN chmod +x /start.sh

USER container
WORKDIR /home/container

CMD ["/start.sh"]